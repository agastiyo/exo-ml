@article{udryHARPSSearchSouthern2006,
  title = {The {{HARPS}} Search for Southern Extra-Solar Planets - {{V}}. {{A}} 14 {{Earth-masses}} Planet Orbiting {{HD}} 4308},
  author = {Udry, S. and Mayor, M. and Benz, W. and Bertaux, J.-L. and Bouchy, F. and Lovis, C. and Mordasini, C. and Pepe, F. and Queloz, D. and Sivan, J.-P.},
  year = 2006,
