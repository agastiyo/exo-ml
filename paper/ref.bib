@article{hubertMacroPCAAllinOnePCA2019,
  title = {{{MacroPCA}}: {{An All-in-One PCA Method Allowing}} for {{Missing Values}} as {{Well}} as {{Cellwise}} and {{Rowwise Outliers}}},
  shorttitle = {{{MacroPCA}}},
  author = {Hubert, Mia and Rousseeuw, Peter J. and {Van den Bossche}, Wannes},
  year = 2019,
