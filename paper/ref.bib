@article{sayeedExoplanetOccurrenceRate2025,
  title = {Exoplanet {{Occurrence Rate}} with {{Age}} for {{FGK Stars}} in {{Kepler}}},
  author = {Sayeed, Maryum and Angus, Ruth and Berger, Travis A. and Lu, Yuxi(Lucy) and Christiansen, Jessie L. and {Foreman-Mackey}, Daniel and Ness, Melissa K.},
  year = 2025,
