}

@inproceedings{mirchandaniDetectionBiasesMethodological2025,
  title = {Detection {{Biases}} and {{Methodological Impacts}} in {{Exoplanet Discovery}}},
  booktitle = {2025 5th {{International Conference}} on {{Soft Computing}} for {{Security Applications}} ({{ICSCSA}})},
  author = {Mirchandani, Shaan and Vishwakarma, Vinay},
  year = 2025,
  month = aug,
  pages = {1522--1530},
  doi = {10.1109/ICSCSA66339.2025.11170927},
  urldate = {2026-04-22},
  abstract = {A lot more information about planets outside our solar system is available now due to exoplanet discoveries. However, the biases introduced by detection methods like Transit and Radial Velocity affect the observed characteristics of detected exoplanets. This work examined how various exoplanet discovery methods shape the observed characteristics of the detected exoplanet population. Advanced statistical analysis and machine learning techniques were used to preprocess the obtained exoplanet dataset and to assess biases in the detection methods. This study represents a unified statistical and machine learning-based framework to quantify and visualize detection biases across discovery methods based upon a comprehensive data set, as compared to previous works that focused on certain detection techniques or a single planetary characteristic. The dataset contained 23 planetary, stellar, and observational parameters obtained from the NASA Exoplanet Archive. The findings showed that the Transit method is biased towards the detection of short-period, low-eccentricity planets, whereas Radial Velocity is suitable for detecting massive planets around larger stars. High-mass and long-period planets are detected by imaging methods. Microlensing is the least biased but underused. Box, Violin and KDE plots show how the biases in detection methods lead to an incomplete picture of exoplanets. Improvement in detection methods is necessary to better understand exoplanets.},
  keywords = {Bias Quantification,Correlation,Correlation Analysis,Eclipse Timing Variations,Exoplanet,Exoplanet Detection Methods Bias,Exoplanetary Characteristics,Imaging,Imputation,Lenses,Microlensing,Microoptics,Missing Data Imputation,Orbital Brightness Modulation,Planetary orbits,Planets,Pulsar Timing Method,Radial Velocity Method,Stars,Timing,Transit Method,Transit Timing Variations},
  file = {/Users/agastya/Zotero/storage/RFGVNES2/Mirchandani and Vishwakarma - 2025 - Detection Biases and Methodological Impacts in Exoplanet Discovery.pdf}
}

@article{muldersINCREASEMASSPLANETARY2015,
  title = {{{AN INCREASE IN THE MASS OF PLANETARY SYSTEMS AROUND LOWER-MASS STARS}}},
  author = {Mulders, Gijs D. and Pascucci, Ilaria and Apai, D{\'a}niel},
  year = 2015,
  month = nov,
  journal = {The Astrophysical Journal},
  volume = {814},
  number = {2},
  pages = {130},
  publisher = {The American Astronomical Society},
  issn = {0004-637X},
  doi = {10.1088/0004-637X/814/2/130},
  urldate = {2025-11-13},
  abstract = {Trends in the planet population with host star mass provide an avenue to constrain planet formation theories. We derive the planet radius distribution function for Kepler stars of different spectral types, sampling a range in host star masses. We find that M dwarf stars have 3.5 times more small planets (1.0--2.8 R{$\bigoplus$}) than main-sequence FGK stars, but two times fewer Neptune-sized and larger ({$>$}2.8 R{$\bigoplus$}) planets. We find no systematic trend in the planet size distribution between spectral types F, G, and K to explain the increasing occurrence rates. Taking into account the mass--radius relationship and heavy-element mass of observed exoplanets, and assuming those are independent of spectral type, we derive the inventory of the heavy-element mass locked up in exoplanets at short orbits. The overall higher planet occurrence rates around M stars are not consistent with the redistribution of the same mass into more, smaller planets. At the orbital periods and planet radii where Kepler observations are complete for all spectral types, the average heavy-element mass locked up in exoplanets increases roughly inversely with stellar mass from 4 M{$\bigoplus$} in F stars to 5 M{$\bigoplus$} in G and K stars to 7 M{$\bigoplus$} in M stars. This trend stands in stark contrast with observed protoplanetary disk masses that decrease toward lower mass stars, and provides a challenge for current planet formation models. Neither models of in situ formation nor migration of fully formed planets are consistent with these results. Instead, these results are indicative of large-scale inward migration of planetary building blocks---either through type-I migration or radial drift of dust grains---that is more efficient for lower mass stars, but does not result in significantly larger or smaller planets.},
  langid = {english},
  file = {/Users/agastya/Zotero/storage/6X94M9K2/Mulders et al. - 2015 - AN INCREASE IN THE MASS OF PLANETARY SYSTEMS AROUND LOWER-MASS STARS.pdf}
}

