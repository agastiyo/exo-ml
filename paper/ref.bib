}

@article{israelianEnhancedLithiumDepletion2009,
  title = {Enhanced Lithium Depletion in {{Sun-like}} Stars with Orbiting Planets},
  author = {Israelian, Garik and Mena, Elisa Delgado and Santos, Nuno C. and Sousa, Sergio G. and Mayor, Michel and Udry, Stephane and Cerde{\~n}a, Carolina Dom{\'i}nguez and Rebolo, Rafael and Randich, Sofia},
