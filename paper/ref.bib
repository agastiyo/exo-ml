@misc{martinez-hernandezDESIREDTemperaturemetallicityRelations2026,
  title = {The {{DESIRED}} Temperature-Metallicity Relations in Star-Forming Regions: Probing the {{Galactic}} Radial and Azimuthal Metallicity Distributions},
  shorttitle = {The {{DESIRED}} Temperature-Metallicity Relations in Star-Forming Regions},
  author = {{Mart{\'i}nez-Hern{\'a}ndez}, I. Rafael and {M{\'e}ndez-Delgado}, J. Eduardo and Esteban, C{\'e}sar and {Garc{\'i}a-Rojas}, Jorge and Carigi, Leticia and Rodr{\'i}guez, Luis F. and Zapata, Luis A. and {Rosales-Ortega}, F. Fabi{\'a}n and {Orte-Garc{\'i}a}, Maialen and {Reyes-Rodr{\'i}guez}, Elena and {Arellano-C{\'o}rdova}, Karla Z. and Kreckel, Kathryn and Sattler, Natascha and Morisset, Christophe and Peimbert, Manuel and {Torres-Peimbert}, Silvia and Pe{\~n}a, Miriam and Chrob{\'a}kov{\'a}, {\v Z}ofia and Zari, Eleonora and {Espinoza-Galeas}, David A.},
  year = 2026,
  month = jan,
  number = {arXiv:2601.13337},
  eprint = {2601.13337},
  primaryclass = {astro-ph},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2601.13337},
  urldate = {2026-02-23},
  abstract = {We analyse a sample of 225 star-forming regions from the DESIRED-E project, each with simultaneous determinations of the electron temperature from ionized nitrogen and oxygen, \$T\_\textbraceleft\textbackslash rm e\textbraceright\$([NII]) and \$T\_\textbraceleft\textbackslash rm e\textbraceright\$([OIII]), respectively. We derive new empirical relations connecting the gas-phase metallicity to the global electron temperature, \$T\_\textbraceleft\textbackslash rm e\textbraceright\$(H\$\textasciicircum +\$), as determined via radio observations. We establish two calibrations: one assuming a homogeneous temperature distribution (\$t\textasciicircum 2 = 0\$, the ``direct method''), and another accounting for internal temperature fluctuations (\$t\textasciicircum 2 {$>$} 0\$). Applying these calibrations to 460 radio observations of Galactic HII\textasciitilde regions spanning Galactocentric distances from \$\textbackslash sim0.1\$ to 16 kpc, we determine the radial O/H gradient in the Milky Way under both assumptions. We further compare these nebular gradients to independent metallicity estimates from young O- and B-type stars and Cepheid variables. We find that the \$t\textasciicircum 2 {$>$} 0\$ calibration yields a gradient in excellent agreement with stellar-based determinations, whereas the \$t\textasciicircum 2 = 0\$ method underestimates metallicities by up to \$\textbackslash sim\$0.3 dex. This discrepancy cannot be reconciled by invoking oxygen depletion onto dust grains or nucleosynthetic processing via the CNO cycle in massive stars. We also find that one widely used relation in the literature, assuming \$t\textasciicircum 2 = 0\$, produces an excessively steep gradient -- likely due to the use of outdated atomic data and pre-CCD observations. Finally, we explore potential azimuthal variations in the Galactic metallicity distribution driven by the presence of the spiral arms, finding no evidence for variations larger than \$\textbackslash sim\$0.1 dex with respect to the general radial gradient.},
  archiveprefix = {arXiv},
  keywords = {Astrophysics - Astrophysics of Galaxies,Astrophysics - Solar and Stellar Astrophysics},
  file = {/Users/agastya/Zotero/storage/ZNANJS3W/Martínez-Hernández et al. - 2026 - The DESIRED temperature-metallicity relations in star-forming regions probing the Galactic radial a.pdf;/Users/agastya/Zotero/storage/ZCEGPEBE/2601.html}
}

